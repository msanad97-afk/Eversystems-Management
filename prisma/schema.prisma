// prisma/schema.prisma
// Full Eversystems Management schema (Part 1 of the spec).
// The ENTIRE schema is migrated in Phase 1 so it never changes again, even though
// report tables are not used until Phase 2 and financial tables not until Phase 6.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ──────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  SUPERVISOR
  VIEWER
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
}

enum ReportStatus {
  DRAFT // Saved but not submitted — editable by author
  SUBMITTED // Locked for author edits pending review (author may recall to DRAFT)
  APPROVED // Final — immutable
  REJECTED // Returned to author with a note — author edits and resubmits
}

// Revision 2: a reportable line is either MEASURED (priced on the parent activity's
// unit, built up from labour + material rates) or LUMPSUM (a fixed BHD total that
// does not scale with quantity).
enum LineType {
  MEASURED
  LUMPSUM
}

enum AuditAction {
  USER_LOGIN
  USER_LOGIN_FAILED
  USER_CREATED
  USER_UPDATED
  USER_STATUS_CHANGED
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
  PROJECT_CREATED
  PROJECT_UPDATED
  PROJECT_MEMBER_ADDED
  PROJECT_MEMBER_REMOVED
  REPORT_CREATED
  REPORT_SUBMITTED
  REPORT_RECALLED
  REPORT_APPROVED
  REPORT_REJECTED
  REPORT_UPDATED
  CATALOG_UPDATED
  ASSET_CREATED
  ASSET_UPDATED
  ACTIVITY_CREATED
  ACTIVITY_UPDATED
  CATALOG_ACTIVITY_CREATED
  CATALOG_ACTIVITY_UPDATED
  CATALOG_ACTIVITY_DELETED
  ACTIVITY_PLACED_FROM_CATALOG
  ACTIVITY_REPRICED
}

// ─── USERS ────────────────────────────────────────────────────────────────────

model User {
  id                 String     @id @default(cuid())
  userCode           String     @unique // USR-00001 — immutable
  email              String     @unique
  passwordHash       String
  firstName          String
  lastName           String
  phone              String?
  role               Role       @default(SUPERVISOR)
  status             UserStatus @default(ACTIVE)
  // Set when an admin creates the user with a temporary password; cleared once the
  // user chooses their own password on first login. (Agreed Phase 0 addition.)
  mustChangePassword Boolean    @default(false)
  lastLoginAt        DateTime?
  resetToken         String?    @unique
  resetTokenExpiry   DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  projects  ProjectMember[]
  reports   DailyReport[]   @relation("ReportAuthor")
  reviews   DailyReport[]   @relation("ReportReviewer")
  auditLogs AuditLog[]
}

// ─── PROJECTS (SITES) ──────────────────────────────────────────────────────────

model Project {
  id          String        @id @default(cuid())
  projectCode String        @unique // PRJ-2026-001 — immutable
  name        String
  location    String?
  status      ProjectStatus @default(ACTIVE)
  startDate   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  createdBy   String

  // ─── Financials (Phase 6). Nullable; unused until then. ───
  // Money amounts carry 3 decimals (BHD fils), consistent with all BHD fields.
  contractValue    Decimal?  @db.Decimal(18, 3)
  currency         String    @default("BHD")
  budgetCost       Decimal?  @db.Decimal(18, 3)
  retentionPct     Decimal?  @db.Decimal(5, 2)
  advancePct       Decimal?  @db.Decimal(5, 2)
  paymentTermsDays Int?      @default(45)
  plannedStart     DateTime? @db.Date
  plannedEnd       DateTime? @db.Date

  members    ProjectMember[]
  reports    DailyReport[]
  counters   ReportCounter[]
  assets     Asset[]
  baseline   BaselinePeriod[]
  valuations Valuation[]
  expenses   Expense[]
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  addedAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

// ─── CATALOGS ───────────────────────────────────────────────────────────────
// Global reference lists managed by ADMIN. Soft-deactivated, never deleted.

model LaborCategory {
  id         String   @id @default(cuid())
  name       String   @unique
  isActive   Boolean  @default(true)
  sortOrder  Int      @default(0)
  hourlyRate Decimal? @db.Decimal(10, 3) // Phase 6: cost per man-hour

  entries            ManpowerEntry[]
  catalogRates       CatalogManpowerRate[]
  subActivityBudgets SubActivityManpowerBudget[]
}

model Material {
  id        String   @id @default(cuid())
  name      String   @unique
  unit      String
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  unitRate  Decimal? @db.Decimal(12, 3) // Phase 6: cost per unit

  entries            MaterialEntry[]
  catalogRates       CatalogMaterialRate[]
  subActivityBudgets SubActivityMaterialBudget[]
}

// ─── CATALOG ACTIVITIES (Rev 2) ───────────────────────────────────────────────
// Reusable activity templates carrying built-in budgets. Placing one on a project
// asset deep-copies it into project-owned rows (Activity/SubActivity/budget) — see
// SubActivity. Templates are soft-deactivated for normal use, but may be hard-deleted;
// because placement is a copy, neither edit nor delete affects any live project.

model CatalogActivity {
  id             String   @id @default(cuid())
  name           String   @unique // "EIFS", "Blockwork 200mm"
  type           LineType @default(MEASURED)
  unit           String? // required if MEASURED; null for a pure-LUMPSUM activity
  lumpsumBhd     Decimal? @db.Decimal(18, 3) // default COST budget in BHD if this activity is LUMPSUM
  // Phase 6A: contract (bill) value. Null → falls back to lumpsumBhd, so "bill defaults to cost".
  lumpsumBillBhd Decimal? @db.Decimal(18, 3)
  description    String?
  isActive       Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())

  subActivities CatalogSubActivity[]
  placements    Activity[] // instances snapshotted from this template (provenance)
}

model CatalogSubActivity {
  id                String   @id @default(cuid())
  catalogActivityId String
  name              String
  type              LineType @default(MEASURED)
  lumpsumBhd        Decimal? @db.Decimal(18, 3) // default COST budget in BHD if this sub-activity is LUMPSUM
  lumpsumBillBhd    Decimal? @db.Decimal(18, 3) // contract value; null → falls back to lumpsumBhd
  sortOrder         Int      @default(0)
  isImplicit        Boolean  @default(false) // hidden line carrying a flat activity's rates

  catalogActivity CatalogActivity       @relation(fields: [catalogActivityId], references: [id], onDelete: Cascade)
  manpowerRates   CatalogManpowerRate[]
  materialRates   CatalogMaterialRate[]

  @@unique([catalogActivityId, name])
}

model CatalogManpowerRate {
  id                   String  @id @default(cuid())
  catalogSubActivityId String
  laborCategoryId      String
  hoursPerUnit         Decimal @db.Decimal(10, 4) // e.g. 0.3 mason-hours per m2

  catalogSubActivity CatalogSubActivity @relation(fields: [catalogSubActivityId], references: [id], onDelete: Cascade)
  category           LaborCategory      @relation(fields: [laborCategoryId], references: [id])

  @@unique([catalogSubActivityId, laborCategoryId])
}

model CatalogMaterialRate {
  id                   String  @id @default(cuid())
  catalogSubActivityId String
  materialId           String
  qtyPerUnit           Decimal @db.Decimal(12, 4) // e.g. 5 kg adhesive per m2

  catalogSubActivity CatalogSubActivity @relation(fields: [catalogSubActivityId], references: [id], onDelete: Cascade)
  material           Material           @relation(fields: [materialId], references: [id])

  @@unique([catalogSubActivityId, materialId])
}

// ─── DAILY REPORTS ──────────────────────────────────────────────────────────

model DailyReport {
  id           String       @id @default(cuid())
  reportCode   String       @unique // DR-2026-0001 — global, immutable
  projectId    String
  authorId     String
  reportDate   DateTime     @db.Date
  status       ReportStatus @default(DRAFT)
  weather      String?
  generalNotes String?
  submittedAt  DateTime?
  reviewedById String?
  reviewedAt   DateTime?
  reviewNote   String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  project    Project @relation(fields: [projectId], references: [id])
  author     User    @relation("ReportAuthor", fields: [authorId], references: [id])
  reviewedBy User?   @relation("ReportReviewer", fields: [reviewedById], references: [id])

  activities ReportActivity[]

  @@unique([projectId, reportDate, authorId])
  @@index([projectId, reportDate])
  @@index([status])
  @@index([authorId])
}

// ─── STRUCTURED SCOPE (Phase R) ───────────────────────────────────────────────
// A project is broken into Assets; each Asset has Activities (BOQ lines with a unit
// and a contracted quantity = the cap). Supervisors report quantityDone per activity.

model Asset {
  id          String   @id @default(cuid())
  projectId   String
  ref         String? // optional admin reference, e.g. "Block A"
  name        String
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true) // soft-deactivate; history preserved
  createdAt   DateTime @default(now())

  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  activities Activity[]

  @@index([projectId])
}

model Activity {
  id             String    @id @default(cuid())
  assetId        String
  ref            String? // optional BOQ item no., e.g. "3.2.1"
  name           String
  // Rev 2: MEASURED lines carry a unit + boqQuantity (the CAP). LUMPSUM lines carry a
  // fixed lumpsumBhd instead and have no unit (unit null, boqQuantity 0, never read).
  type           LineType  @default(MEASURED)
  unit           String? // required for MEASURED; null for LUMPSUM
  boqQuantity    Decimal   @db.Decimal(14, 3) // contracted/planned quantity — the CAP (0 for LUMPSUM)
  lumpsumBhd     Decimal?  @db.Decimal(18, 3) // fixed COST budget in BHD if LUMPSUM (frozen at placement)
  // Phase 6A: contract (bill) value for a lumpsum line; null → falls back to lumpsumBhd.
  lumpsumBillBhd Decimal?  @db.Decimal(18, 3)
  // Phase 6A: when the global resource cost rates were last snapshotted onto this
  // activity's budget rows (placement, or an explicit admin re-price).
  pricedAt       DateTime?
  sortOrder      Int       @default(0)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())

  // Provenance only — which catalog template this was snapshotted from (null = one-off).
  // NEVER read when deriving a budget; SetNull so deleting the template can't touch this row.
  catalogActivityId String?

  // ─── Phase 6 (nullable, unused until then): unit rates for bottom-up EVM. ───
  costRate Decimal? @db.Decimal(14, 3) // planned cost per unit — budget / AC basis
  billRate Decimal? @db.Decimal(14, 3) // contract value per unit — PV / earned revenue

  asset           Asset            @relation(fields: [assetId], references: [id], onDelete: Cascade)
  catalogActivity CatalogActivity? @relation(fields: [catalogActivityId], references: [id], onDelete: SetNull)
  subActivities   SubActivity[]
  progress        ReportActivity[]

  @@index([assetId])
  @@index([catalogActivityId])
}

// ─── PROJECT-OWNED SUB-ACTIVITIES (Rev 2, snapshot/frozen at placement) ───────
// A reportable line is a SubActivity (when the activity has them) or the activity
// itself (flat one-off). A MEASURED activity with rates but no named sub-activities
// stores them on a single implicit SubActivity (isImplicit) — never shown in any UI —
// so budget + reporting always run one code path at the sub-activity level.
// The budget rows below hold COPIES of the catalog rates; they have NO foreign key
// back to the catalog, so editing/deleting a catalog activity never touches them.

model SubActivity {
  id             String   @id @default(cuid())
  activityId     String
  name           String
  type           LineType @default(MEASURED)
  lumpsumBhd     Decimal? @db.Decimal(18, 3) // frozen COST budget in BHD if this sub-activity is LUMPSUM
  lumpsumBillBhd Decimal? @db.Decimal(18, 3) // contract value; null → falls back to lumpsumBhd
  sortOrder      Int      @default(0)
  isActive       Boolean  @default(true)
  isImplicit     Boolean  @default(false) // the hidden single line carrying a flat activity's rates
  createdAt      DateTime @default(now())

  activity       Activity                    @relation(fields: [activityId], references: [id], onDelete: Cascade)
  manpowerBudget SubActivityManpowerBudget[]
  materialBudget SubActivityMaterialBudget[]
  progress       ReportSubActivity[]

  @@unique([activityId, name])
  @@index([activityId])
}

model SubActivityManpowerBudget {
  id                  String   @id @default(cuid())
  subActivityId       String
  laborCategoryId     String
  hoursPerUnit        Decimal  @db.Decimal(10, 4) // frozen copy of the catalog QUANTITY rate
  // Phase 6A: frozen copy of the GLOBAL LaborCategory.hourlyRate at placement. Global rates
  // are shared across projects, so they are snapshotted here — editing the catalog rate can
  // never re-price a placed budget. Null = the trade was unpriced at placement.
  costRateAtPlacement Decimal? @db.Decimal(10, 3)

  subActivity SubActivity   @relation(fields: [subActivityId], references: [id], onDelete: Cascade)
  category    LaborCategory @relation(fields: [laborCategoryId], references: [id])

  @@unique([subActivityId, laborCategoryId])
}

model SubActivityMaterialBudget {
  id                  String   @id @default(cuid())
  subActivityId       String
  materialId          String
  qtyPerUnit          Decimal  @db.Decimal(12, 4) // frozen copy of the catalog QUANTITY rate
  // Phase 6A: frozen copy of the GLOBAL Material.unitRate at placement (see above).
  costRateAtPlacement Decimal? @db.Decimal(12, 3)

  subActivity SubActivity @relation(fields: [subActivityId], references: [id], onDelete: Cascade)
  material    Material    @relation(fields: [materialId], references: [id])

  @@unique([subActivityId, materialId])
}

// Phase C2: ReportActivity is a lightweight GROUP (the activity touched on a report); the
// actual progress + manpower/materials live one level down, on ReportSubActivity. Every
// reportable line is a sub-activity (implicit when the activity has no named ones), so
// reporting runs one code path and entries never hang off two levels.
model ReportActivity {
  id         String  @id @default(cuid())
  reportId   String
  activityId String
  note       String? // optional activity-level note
  sortOrder  Int     @default(0)

  report        DailyReport         @relation(fields: [reportId], references: [id], onDelete: Cascade)
  activity      Activity            @relation(fields: [activityId], references: [id])
  subActivities ReportSubActivity[]

  @@unique([reportId, activityId]) // an activity appears at most once per report
  @@index([activityId])
}

model ReportSubActivity {
  id               String   @id @default(cuid())
  reportActivityId String
  subActivityId    String
  quantityDone     Decimal? @db.Decimal(14, 3) // MEASURED: increment reported on this date
  percentComplete  Decimal? @db.Decimal(6, 3) // LUMPSUM: cumulative % complete (0–100)
  note             String?
  sortOrder        Int      @default(0)

  reportActivity ReportActivity  @relation(fields: [reportActivityId], references: [id], onDelete: Cascade)
  subActivity    SubActivity     @relation(fields: [subActivityId], references: [id])
  manpower       ManpowerEntry[]
  materials      MaterialEntry[]

  @@unique([reportActivityId, subActivityId]) // a sub-activity appears at most once per activity
  @@index([subActivityId])
}

model ManpowerEntry {
  id                  String  @id @default(cuid())
  reportSubActivityId String
  categoryId          String
  headcount           Int
  hours               Decimal @db.Decimal(5, 2)
  notes               String?

  // Phase 6: cost snapshot, populated once on report approval.
  rateAtApproval Decimal? @db.Decimal(12, 3)
  costAtApproval Decimal? @db.Decimal(14, 3)

  reportSubActivity ReportSubActivity @relation(fields: [reportSubActivityId], references: [id], onDelete: Cascade)
  category          LaborCategory     @relation(fields: [categoryId], references: [id])

  @@unique([reportSubActivityId, categoryId])
}

model MaterialEntry {
  id                  String  @id @default(cuid())
  reportSubActivityId String
  materialId          String
  quantity            Decimal @db.Decimal(12, 3)
  notes               String?

  // Phase 6: cost snapshot, populated once on report approval.
  rateAtApproval Decimal? @db.Decimal(12, 3)
  costAtApproval Decimal? @db.Decimal(14, 3)

  reportSubActivity ReportSubActivity @relation(fields: [reportSubActivityId], references: [id], onDelete: Cascade)
  material          Material          @relation(fields: [materialId], references: [id])

  @@unique([reportSubActivityId, materialId])
}

// ─── REPORT NUMBERING (no Redis) ─────────────────────────────────────────────

model ReportCounter {
  id        String  @id @default(cuid())
  scope     String  @unique // "report:2026", "user", "project:2026"
  value     Int     @default(0)
  projectId String?

  project Project? @relation(fields: [projectId], references: [id])
}

// ─── AUDIT LOG (light) ────────────────────────────────────────────────────────

model AuditLog {
  id         String      @id @default(cuid())
  action     AuditAction
  userId     String?
  projectId  String?
  entity     String?
  entityId   String?
  entityCode String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([action])
  @@index([projectId])
  @@index([createdAt])
}

// ─── FINANCIAL LAYER (Phases 6–9). Migrated now; unused until then. ───────────

enum ValuationStatus {
  DRAFT
  SUBMITTED
  CERTIFIED
  INVOICED
  PAID
}

enum ExpenseCategory {
  SUBCONTRACTOR
  EQUIPMENT_RENTAL
  SALARIES_INDIRECT
  SITE_OVERHEAD
  HEAD_OFFICE_OVERHEAD
  MATERIALS_DIRECT
  OTHER
}

enum CashDirection {
  IN
  OUT
}

enum CashCategory {
  VALUATION_RECEIPT
  ADVANCE_PAYMENT
  RETENTION_RELEASE
  SUPPLIER_PAYMENT
  SUBCONTRACTOR_PAYMENT
  PAYROLL
  EQUIPMENT
  OVERHEAD
  VAT_TAX
  LOAN_FINANCE
  OTHER_IN
  OTHER_OUT
}

model BaselinePeriod {
  id          String   @id @default(cuid())
  projectId   String
  periodMonth DateTime @db.Date
  plannedPct  Decimal  @db.Decimal(6, 3)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, periodMonth])
}

model Valuation {
  id              String          @id @default(cuid())
  valuationCode   String          @unique
  projectId       String
  periodMonth     DateTime        @db.Date
  progressPct     Decimal         @db.Decimal(6, 3)
  grossAmount     Decimal         @db.Decimal(18, 3)
  previousGross   Decimal         @db.Decimal(18, 3)
  retentionHeld   Decimal         @db.Decimal(18, 3)
  advanceRecovery Decimal         @db.Decimal(18, 3)
  netPayable      Decimal         @db.Decimal(18, 3)
  status          ValuationStatus @default(DRAFT)
  certifiedAt     DateTime?
  expectedReceipt DateTime?       @db.Date
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  createdBy       String

  project  Project           @relation(fields: [projectId], references: [id])
  receipts CashTransaction[]

  @@unique([projectId, periodMonth])
}

model Expense {
  id          String          @id @default(cuid())
  projectId   String?
  category    ExpenseCategory
  description String
  vendor      String?
  expenseDate DateTime        @db.Date
  amount      Decimal         @db.Decimal(18, 3)
  createdAt   DateTime        @default(now())
  createdBy   String

  project Project? @relation(fields: [projectId], references: [id])

  @@index([projectId, expenseDate])
}

model BankAccount {
  id             String   @id @default(cuid())
  name           String
  currency       String   @default("BHD")
  openingBalance Decimal  @db.Decimal(18, 3)
  openingDate    DateTime @db.Date
  isActive       Boolean  @default(true)

  transactions CashTransaction[]
}

model CashTransaction {
  id          String        @id @default(cuid())
  accountId   String
  txnDate     DateTime      @db.Date
  direction   CashDirection
  category    CashCategory
  amount      Decimal       @db.Decimal(18, 3)
  description String
  projectId   String?
  valuationId String?
  expenseId   String?
  createdAt   DateTime      @default(now())
  createdBy   String

  account   BankAccount @relation(fields: [accountId], references: [id])
  valuation Valuation?  @relation(fields: [valuationId], references: [id])

  @@index([accountId, txnDate])
  @@index([projectId])
}
