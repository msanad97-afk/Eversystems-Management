// prisma/schema.prisma
// Full Eversystems Management schema (Part 1 of the spec).
// The ENTIRE schema is migrated in Phase 1 so it never changes again, even though
// report tables are not used until Phase 2 and financial tables not until Phase 6.

generator client {
  provider      = "prisma-client-js"
  // native = local dev; rhel-openssl-3.0.x = Vercel/AWS Lambda (Amazon Linux) runtime.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // POOLED (Neon pooler) — serverless runtime
  directUrl = env("DIRECT_URL")   // UNPOOLED — prisma migrate/introspect
}

// ─── ENUMS ──────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  SUPERVISOR
  VIEWER
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
}

enum ReportStatus {
  DRAFT // Saved but not submitted — editable by author
  SUBMITTED // Locked for author edits pending review (author may recall to DRAFT)
  APPROVED // Final — immutable
  REJECTED // Returned to author with a note — author edits and resubmits
}

// Revision 2: a reportable line is either MEASURED (priced on the parent activity's
// unit, built up from labour + material rates) or LUMPSUM (a fixed BHD total that
// does not scale with quantity).
enum LineType {
  MEASURED
  LUMPSUM
}

enum AuditAction {
  USER_LOGIN
  USER_LOGIN_FAILED
  USER_CREATED
  USER_UPDATED
  USER_STATUS_CHANGED
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
  PROJECT_CREATED
  PROJECT_UPDATED
  PROJECT_MEMBER_ADDED
  PROJECT_MEMBER_REMOVED
  REPORT_CREATED
  REPORT_SUBMITTED
  REPORT_RECALLED
  REPORT_APPROVED
  REPORT_REJECTED
  REPORT_UPDATED
  CATALOG_UPDATED
  ASSET_CREATED
  ASSET_UPDATED
  ACTIVITY_CREATED
  ACTIVITY_UPDATED
  ACTIVITY_DELETED
  CATALOG_ACTIVITY_CREATED
  CATALOG_ACTIVITY_UPDATED
  CATALOG_ACTIVITY_DELETED
  ACTIVITY_PLACED_FROM_CATALOG
  ACTIVITY_REPRICED
  EXPENSE_CREATED
  EXPENSE_UPDATED
  EXPENSE_DELETED
  REPORT_COST_BACKFILLED
  BASELINE_UPDATED
  VALUATION_CREATED
  VALUATION_UPDATED
  VALUATION_SUBMITTED
  VALUATION_CERTIFIED
  VALUATION_REISSUED
  VALUATION_INVOICED
  VALUATION_RECALLED
  BANK_ACCOUNT_CREATED
  BANK_ACCOUNT_UPDATED
  CASH_TXN_CREATED
  CASH_TXN_UPDATED
  CASH_TXN_DELETED
}

// ─── USERS ────────────────────────────────────────────────────────────────────

model User {
  id                 String     @id @default(cuid())
  userCode           String     @unique // USR-00001 — immutable
  email              String     @unique
  passwordHash       String
  firstName          String
  lastName           String
  phone              String?
  role               Role       @default(SUPERVISOR)
  status             UserStatus @default(ACTIVE)
  // Set when an admin creates the user with a temporary password; cleared once the
  // user chooses their own password on first login. (Agreed Phase 0 addition.)
  mustChangePassword Boolean    @default(false)
  lastLoginAt        DateTime?
  resetToken         String?    @unique
  resetTokenExpiry   DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  projects  ProjectMember[]
  reports   DailyReport[]   @relation("ReportAuthor")
  reviews   DailyReport[]   @relation("ReportReviewer")
  auditLogs AuditLog[]
}

// ─── PROJECTS (SITES) ──────────────────────────────────────────────────────────

model Project {
  id          String        @id @default(cuid())
  projectCode String        @unique // PRJ-2026-001 — immutable
  name        String
  location    String?
  status      ProjectStatus @default(ACTIVE)
  startDate   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  createdBy   String

  // ─── Financials (Phase 6). Nullable; unused until then. ───
  // Money amounts carry 3 decimals (BHD fils), consistent with all BHD fields.
  contractValue    Decimal?  @db.Decimal(18, 3)
  currency         String    @default("BHD")
  budgetCost       Decimal?  @db.Decimal(18, 3)
  retentionPct     Decimal?  @db.Decimal(5, 2)
  // Phase 6D: retention stops accruing once held retention reaches this % of contract value.
  // Null = uncapped (retentionPct applies to cumulative gross without limit).
  retentionCapPct  Decimal?  @db.Decimal(5, 2)
  advancePct       Decimal?  @db.Decimal(5, 2)
  paymentTermsDays Int?      @default(45)
  plannedStart     DateTime? @db.Date
  plannedEnd       DateTime? @db.Date
  // Phase 8: retention release. Held retention is derived from certificates (6D); a release is
  // a manual RETENTION_RELEASE cash receipt. These drive the presentational release tranches.
  practicalCompletionDate  DateTime? @db.Date          // trigger for tranche 1
  defectsLiabilityMonths   Int?      @default(12)       // tranche 2 due = PC date + this
  retentionFirstReleasePct Decimal?  @db.Decimal(5, 2) @default(50) // % released at PC

  members          ProjectMember[]
  reports          DailyReport[]
  counters         ReportCounter[]
  assets           Asset[]
  baseline         BaselinePeriod[]
  valuations       Valuation[]
  expenses         Expense[]
  cashTransactions CashTransaction[] // Phase 6E: cash movements allocated to this project
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  addedAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

// ─── CATALOGS ───────────────────────────────────────────────────────────────
// Global reference lists managed by ADMIN. Soft-deactivated, never deleted.

model LaborCategory {
  id         String   @id @default(cuid())
  name       String   @unique
  isActive   Boolean  @default(true)
  sortOrder  Int      @default(0)
  hourlyRate Decimal? @db.Decimal(10, 3) // Phase 6: cost per man-hour

  entries            ManpowerEntry[]
  catalogRates       CatalogManpowerRate[]
  subActivityBudgets SubActivityManpowerBudget[]
}

model Material {
  id        String   @id @default(cuid())
  name      String   @unique
  unit      String
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  unitRate  Decimal? @db.Decimal(12, 3) // Phase 6: cost per unit

  entries            MaterialEntry[]
  catalogRates       CatalogMaterialRate[]
  subActivityBudgets SubActivityMaterialBudget[]
}

// ─── CATALOG ACTIVITIES (Rev 2) ───────────────────────────────────────────────
// Reusable activity templates carrying built-in budgets. Placing one on a project
// asset deep-copies it into project-owned rows (Activity/SubActivity/budget) — see
// SubActivity. Templates are soft-deactivated for normal use, but may be hard-deleted;
// because placement is a copy, neither edit nor delete affects any live project.

model CatalogActivity {
  id          String   @id @default(cuid())
  name        String   @unique // "EIFS", "Blockwork 200mm"
  type        LineType @default(MEASURED)
  unit        String? // required if MEASURED; null for a pure-LUMPSUM activity
  // A lumpsum is a COST to complete the activity. It raises the cost budget (BAC) and
  // contributes NOTHING to contract value — billing happens at asset/project level, never
  // on an activity line. (The Phase 6A "bill defaults to cost" behaviour was wrong.)
  lumpsumBhd  Decimal? @db.Decimal(18, 3)
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  subActivities CatalogSubActivity[]
  placements    Activity[] // instances snapshotted from this template (provenance)
}

model CatalogSubActivity {
  id                String   @id @default(cuid())
  catalogActivityId String
  name              String
  type              LineType @default(MEASURED)
  lumpsumBhd        Decimal? @db.Decimal(18, 3) // default COST budget in BHD if this sub-activity is LUMPSUM (cost only)
  sortOrder         Int      @default(0)
  isImplicit        Boolean  @default(false) // hidden line carrying a flat activity's rates

  catalogActivity CatalogActivity       @relation(fields: [catalogActivityId], references: [id], onDelete: Cascade)
  manpowerRates   CatalogManpowerRate[]
  materialRates   CatalogMaterialRate[]

  @@unique([catalogActivityId, name])
}

model CatalogManpowerRate {
  id                   String  @id @default(cuid())
  catalogSubActivityId String
  laborCategoryId      String
  hoursPerUnit         Decimal @db.Decimal(10, 4) // e.g. 0.3 mason-hours per m2

  catalogSubActivity CatalogSubActivity @relation(fields: [catalogSubActivityId], references: [id], onDelete: Cascade)
  category           LaborCategory      @relation(fields: [laborCategoryId], references: [id])

  @@unique([catalogSubActivityId, laborCategoryId])
}

model CatalogMaterialRate {
  id                   String  @id @default(cuid())
  catalogSubActivityId String
  materialId           String
  qtyPerUnit           Decimal @db.Decimal(12, 4) // e.g. 5 kg adhesive per m2

  catalogSubActivity CatalogSubActivity @relation(fields: [catalogSubActivityId], references: [id], onDelete: Cascade)
  material           Material           @relation(fields: [materialId], references: [id])

  @@unique([catalogSubActivityId, materialId])
}

// ─── DAILY REPORTS ──────────────────────────────────────────────────────────

model DailyReport {
  id               String       @id @default(cuid())
  reportCode       String       @unique // DR-2026-0001 — global, immutable
  projectId        String
  authorId         String
  reportDate       DateTime     @db.Date
  status           ReportStatus @default(DRAFT)
  weather          String?
  generalNotes     String?
  submittedAt      DateTime?
  reviewedById     String?
  reviewedAt       DateTime?
  reviewNote       String?
  // Phase 6B: set when this report's entry costs were filled in AFTER approval by the admin
  // backfill action (priced at then-current rates, not at approval time). Any actual cost
  // derived from such a report is an APPROXIMATION and must be labelled as one everywhere.
  costBackfilledAt DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  project    Project @relation(fields: [projectId], references: [id])
  author     User    @relation("ReportAuthor", fields: [authorId], references: [id])
  reviewedBy User?   @relation("ReportReviewer", fields: [reviewedById], references: [id])

  activities ReportActivity[]

  @@unique([projectId, reportDate, authorId])
  @@index([projectId, reportDate])
  @@index([status])
  @@index([authorId])
}

// ─── STRUCTURED SCOPE (Phase R) ───────────────────────────────────────────────
// A project is broken into Assets; each Asset has Activities (BOQ lines with a unit
// and a contracted quantity = the cap). Supervisors report quantityDone per activity.

model Asset {
  id          String   @id @default(cuid())
  projectId   String
  ref         String? // optional admin reference, e.g. "Block A"
  name        String
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true) // soft-deactivate; history preserved
  createdAt   DateTime @default(now())

  // Phase 6D: the client bill value for this asset's LUMP-SUM scope. Lump-sum activities are
  // costs with no rate and no quantity, so they cannot bill bottom-up like measured lines —
  // this is the only revenue path they have. Null = "no lump-sum billing agreed yet": the
  // lump-sum stream certifies at 0 and the certify gate blocks.
  lumpsumRevenue Decimal? @db.Decimal(18, 3)

  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  activities Activity[]

  @@index([projectId])
}

model Activity {
  id             String    @id @default(cuid())
  assetId        String
  ref            String? // optional BOQ item no., e.g. "3.2.1"
  name           String
  // Rev 2: MEASURED lines carry a unit + boqQuantity (the CAP). LUMPSUM lines carry a
  // fixed lumpsumBhd instead and have no unit (unit null, boqQuantity 0, never read).
  type           LineType  @default(MEASURED)
  unit           String? // required for MEASURED; null for LUMPSUM
  boqQuantity Decimal   @db.Decimal(14, 3) // contracted/planned quantity — the CAP (0 for LUMPSUM)
  // A lumpsum is a COST to complete this activity (frozen at placement). It raises BAC and
  // contributes ZERO to contract value — only billRate × boqQuantity earns revenue.
  lumpsumBhd  Decimal?  @db.Decimal(18, 3)
  // Phase 6A: when the global resource cost rates were last snapshotted onto this
  // activity's budget rows (placement, or an explicit admin re-price).
  pricedAt    DateTime?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  // Provenance only — which catalog template this was snapshotted from (null = one-off).
  // NEVER read when deriving a budget; SetNull so deleting the template can't touch this row.
  catalogActivityId String?

  // ─── Phase 6 (nullable, unused until then): unit rates for bottom-up EVM. ───
  costRate Decimal? @db.Decimal(14, 3) // planned cost per unit — budget / AC basis
  billRate Decimal? @db.Decimal(14, 3) // contract value per unit — PV / earned revenue

  asset           Asset            @relation(fields: [assetId], references: [id], onDelete: Cascade)
  catalogActivity CatalogActivity? @relation(fields: [catalogActivityId], references: [id], onDelete: SetNull)
  subActivities   SubActivity[]
  progress        ReportActivity[]

  @@index([assetId])
  @@index([catalogActivityId])
}

// ─── PROJECT-OWNED SUB-ACTIVITIES (Rev 2, snapshot/frozen at placement) ───────
// A reportable line is a SubActivity (when the activity has them) or the activity
// itself (flat one-off). A MEASURED activity with rates but no named sub-activities
// stores them on a single implicit SubActivity (isImplicit) — never shown in any UI —
// so budget + reporting always run one code path at the sub-activity level.
// The budget rows below hold COPIES of the catalog rates; they have NO foreign key
// back to the catalog, so editing/deleting a catalog activity never touches them.

model SubActivity {
  id         String   @id @default(cuid())
  activityId String
  name       String
  type       LineType @default(MEASURED)
  lumpsumBhd Decimal? @db.Decimal(18, 3) // frozen COST budget in BHD if this sub-activity is LUMPSUM (cost only)
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  isImplicit Boolean  @default(false) // the hidden single line carrying a flat activity's rates
  createdAt  DateTime @default(now())

  activity       Activity                    @relation(fields: [activityId], references: [id], onDelete: Cascade)
  manpowerBudget SubActivityManpowerBudget[]
  materialBudget SubActivityMaterialBudget[]
  progress       ReportSubActivity[]

  @@unique([activityId, name])
  @@index([activityId])
}

model SubActivityManpowerBudget {
  id                  String   @id @default(cuid())
  subActivityId       String
  laborCategoryId     String
  hoursPerUnit        Decimal  @db.Decimal(10, 4) // frozen copy of the catalog QUANTITY rate
  // Phase 6A: frozen copy of the GLOBAL LaborCategory.hourlyRate at placement. Global rates
  // are shared across projects, so they are snapshotted here — editing the catalog rate can
  // never re-price a placed budget. Null = the trade was unpriced at placement.
  costRateAtPlacement Decimal? @db.Decimal(10, 3)

  subActivity SubActivity   @relation(fields: [subActivityId], references: [id], onDelete: Cascade)
  category    LaborCategory @relation(fields: [laborCategoryId], references: [id])

  @@unique([subActivityId, laborCategoryId])
}

model SubActivityMaterialBudget {
  id                  String   @id @default(cuid())
  subActivityId       String
  materialId          String
  qtyPerUnit          Decimal  @db.Decimal(12, 4) // frozen copy of the catalog QUANTITY rate
  // Phase 6A: frozen copy of the GLOBAL Material.unitRate at placement (see above).
  costRateAtPlacement Decimal? @db.Decimal(12, 3)

  subActivity SubActivity @relation(fields: [subActivityId], references: [id], onDelete: Cascade)
  material    Material    @relation(fields: [materialId], references: [id])

  @@unique([subActivityId, materialId])
}

// Phase C2: ReportActivity is a lightweight GROUP (the activity touched on a report); the
// actual progress + manpower/materials live one level down, on ReportSubActivity. Every
// reportable line is a sub-activity (implicit when the activity has no named ones), so
// reporting runs one code path and entries never hang off two levels.
model ReportActivity {
  id         String  @id @default(cuid())
  reportId   String
  activityId String
  note       String? // optional activity-level note
  sortOrder  Int     @default(0)

  report        DailyReport         @relation(fields: [reportId], references: [id], onDelete: Cascade)
  activity      Activity            @relation(fields: [activityId], references: [id])
  subActivities ReportSubActivity[]

  @@unique([reportId, activityId]) // an activity appears at most once per report
  @@index([activityId])
}

model ReportSubActivity {
  id               String   @id @default(cuid())
  reportActivityId String
  subActivityId    String
  quantityDone     Decimal? @db.Decimal(14, 3) // MEASURED: increment reported on this date
  percentComplete  Decimal? @db.Decimal(6, 3) // LUMPSUM: cumulative % complete (0–100)
  note             String?
  sortOrder        Int      @default(0)

  reportActivity ReportActivity  @relation(fields: [reportActivityId], references: [id], onDelete: Cascade)
  subActivity    SubActivity     @relation(fields: [subActivityId], references: [id])
  manpower       ManpowerEntry[]
  materials      MaterialEntry[]

  @@unique([reportActivityId, subActivityId]) // a sub-activity appears at most once per activity
  @@index([subActivityId])
}

model ManpowerEntry {
  id                  String  @id @default(cuid())
  reportSubActivityId String
  categoryId          String
  headcount           Int
  hours               Decimal @db.Decimal(5, 2)
  notes               String?

  // Phase 6: cost snapshot, populated once on report approval.
  rateAtApproval Decimal? @db.Decimal(12, 3)
  costAtApproval Decimal? @db.Decimal(14, 3)

  reportSubActivity ReportSubActivity @relation(fields: [reportSubActivityId], references: [id], onDelete: Cascade)
  category          LaborCategory     @relation(fields: [categoryId], references: [id])

  @@unique([reportSubActivityId, categoryId])
}

model MaterialEntry {
  id                  String  @id @default(cuid())
  reportSubActivityId String
  materialId          String
  quantity            Decimal @db.Decimal(12, 3)
  notes               String?

  // Phase 6: cost snapshot, populated once on report approval.
  rateAtApproval Decimal? @db.Decimal(12, 3)
  costAtApproval Decimal? @db.Decimal(14, 3)

  reportSubActivity ReportSubActivity @relation(fields: [reportSubActivityId], references: [id], onDelete: Cascade)
  material          Material          @relation(fields: [materialId], references: [id])

  @@unique([reportSubActivityId, materialId])
}

// ─── REPORT NUMBERING (no Redis) ─────────────────────────────────────────────

model ReportCounter {
  id        String  @id @default(cuid())
  scope     String  @unique // "report:2026", "user", "project:2026"
  value     Int     @default(0)
  projectId String?

  project Project? @relation(fields: [projectId], references: [id])
}

// ─── AUDIT LOG (light) ────────────────────────────────────────────────────────

model AuditLog {
  id         String      @id @default(cuid())
  action     AuditAction
  userId     String?
  projectId  String?
  entity     String?
  entityId   String?
  entityCode String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([action])
  @@index([projectId])
  @@index([createdAt])
}

// ─── FINANCIAL LAYER (Phases 6–9). Migrated now; unused until then. ───────────

enum ValuationStatus {
  DRAFT
  SUBMITTED
  CERTIFIED
  INVOICED
  PAID
}

enum ExpenseCategory {
  SUBCONTRACTOR
  EQUIPMENT_RENTAL
  SALARIES_INDIRECT
  SITE_OVERHEAD
  HEAD_OFFICE_OVERHEAD
  MATERIALS_DIRECT
  OTHER
}

enum CashDirection {
  IN
  OUT
}

enum CashCategory {
  VALUATION_RECEIPT
  ADVANCE_PAYMENT
  RETENTION_RELEASE
  SUPPLIER_PAYMENT
  SUBCONTRACTOR_PAYMENT
  PAYROLL
  EQUIPMENT
  OVERHEAD
  VAT_TAX
  LOAN_FINANCE
  OTHER_IN
  OTHER_OUT
}

// Phase 6C: the project baseline S-curve — the ONE manager-entered plan in the system.
// Stored as CUMULATIVE percent of BAC by month-end on the 0–100 scale (house convention),
// not frozen currency, so PV re-prices cleanly when BAC changes — no re-baseline ritual.
// The audit log (BASELINE_UPDATED) is the provenance record; no per-row createdBy/At.
model BaselinePeriod {
  id            String   @id @default(cuid())
  projectId     String
  periodMonth   DateTime @db.Date // first day of the month, UTC-normalised
  cumPlannedPct Decimal  @db.Decimal(6, 3) // cumulative % of BAC by month-end, 0–100

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, periodMonth]) // also serves the ordered read
}

// Phase 6D: an interim payment certificate (IPC) — one per project per month, cumulative
// minus previous. A month can carry several REVISIONS over time (a client can require changes
// to a certificate they already approved); exactly one is LIVE (supersededAt null) and every
// superseded revision stays frozen and readable as the record of what was approved.
model Valuation {
  id            String   @id @default(cuid())
  valuationCode String   @unique // VAL-2026-0001, then VAL-2026-0001-r1, -r2 … per revision
  projectId     String
  periodMonth   DateTime @db.Date

  // Money — RECOMPUTED on every DRAFT edit, FROZEN at certify.
  progressPct        Decimal @db.Decimal(6, 3) // derived display: cumulativeGross ÷ contract value
  cumulativeMeasured Decimal @db.Decimal(18, 3)
  cumulativeLumpsum  Decimal @db.Decimal(18, 3)
  grossAmount        Decimal @db.Decimal(18, 3) // cumulative gross to date
  previousGross      Decimal @db.Decimal(18, 3) // prior period's certified cumulative gross
  retentionHeld      Decimal @db.Decimal(18, 3) // cumulative retention held to date
  advanceRecovery    Decimal @db.Decimal(18, 3) // recovered THIS period
  netPayable         Decimal @db.Decimal(18, 3) // net payable THIS period

  // Certify-time PARAMETER snapshots — nullable, set only at certify. A DRAFT has no
  // certified parameters, so a non-null value here would be a lie.
  contractValueAtCert Decimal? @db.Decimal(18, 3)
  retentionPctAtCert  Decimal? @db.Decimal(5, 2)
  advancePctAtCert    Decimal? @db.Decimal(5, 2)

  // Revisions. supersededAt null = the live revision. The one-live-revision-per-month
  // invariant is enforced in the create check and the re-issue transaction — deliberately NOT
  // a partial unique index, which Prisma cannot express and `migrate diff` would silently drop.
  revisionNumber Int       @default(0)
  supersededAt   DateTime?

  // `status` is the CERTIFICATION machine (DRAFT → SUBMITTED → CERTIFIED). Phase 6E NEVER
  // writes it: the prior-period lookups filter on status='CERTIFIED', so advancing a paid
  // certificate to INVOICED/PAID would drop it from that lookup and silently re-bill it.
  // The INVOICED/PAID enum values are therefore intentionally vestigial — payment state is
  // DERIVED from invoicedAt + matched receipts (Phase 6E), never from status.
  status          ValuationStatus @default(DRAFT)
  certifiedAt     DateTime?
  invoicedAt      DateTime?       @db.Date // Phase 6E — the one manual payment-side step
  expectedReceipt DateTime?       @db.Date
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  createdBy       String

  project  Project           @relation(fields: [projectId], references: [id])
  lines    ValuationLine[]
  receipts CashTransaction[]

  @@unique([projectId, periodMonth, revisionNumber])
  @@index([projectId, periodMonth])
}

// Per-asset detail for one valuation revision. Written for a DRAFT (recomputed on edit) and
// frozen at certify. Stores cumulative-to-date; "this period" per asset = this line minus the
// matching line on the prior certified valuation.
model ValuationLine {
  id                 String  @id @default(cuid())
  valuationId        String
  assetId            String // provenance only; never a live read after certify
  assetName          String // frozen label — survives an asset rename or soft-delete
  cumulativeMeasured Decimal @db.Decimal(18, 3)
  cumulativeLumpsum  Decimal @db.Decimal(18, 3)
  cumulativeGross    Decimal @db.Decimal(18, 3)
  sortOrder          Int     @default(0)

  valuation Valuation @relation(fields: [valuationId], references: [id], onDelete: Cascade)

  @@index([valuationId])
}

model Expense {
  id          String          @id @default(cuid())
  projectId   String?
  category    ExpenseCategory
  description String
  vendor      String?
  expenseDate DateTime        @db.Date // when the cost was INCURRED — feeds Actual Cost (6B), unchanged
  amount      Decimal         @db.Decimal(18, 3)
  // Phase 7: when the expense is PAYABLE — a pure cash-timing field, distinct from expenseDate
  // and never read by the AC path. Null = no agreed terms → "unscheduled payables", reported
  // separately from the forecast buckets (never treated as due now).
  dueDate     DateTime?       @db.Date
  createdAt   DateTime        @default(now())
  createdBy   String

  project  Project?          @relation(fields: [projectId], references: [id])
  payments CashTransaction[] // Phase 6E: cash movements that settled this expense

  @@index([projectId, expenseDate])
}

model BankAccount {
  id             String   @id @default(cuid())
  name           String
  currency       String   @default("BHD")
  openingBalance Decimal  @db.Decimal(18, 3)
  openingDate    DateTime @db.Date
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now()) // Phase 6E — house pattern
  createdBy      String   // Phase 6E

  transactions CashTransaction[]
}

// Phase 6E: a manual record of money moving through a bank account. Unlike a valuation
// (a document issued to a client, frozen at certify), a ledger line is a typo waiting to be
// corrected — it is editable and deletable by ADMIN, and the audit log is its history.
// `direction` is DERIVED server-side from `category` (every category has one valid direction),
// so a client-supplied direction is ignored — the OUT+VALUATION_RECEIPT contradiction class
// cannot occur.
model CashTransaction {
  id          String        @id @default(cuid())
  accountId   String
  txnDate     DateTime      @db.Date
  direction   CashDirection // derived from category, never trusted from the client
  category    CashCategory
  amount      Decimal       @db.Decimal(18, 3) // always > 0; direction carries the sign
  description String
  projectId   String?
  valuationId String?
  expenseId   String?
  clearedAt   DateTime?     @db.Date // Phase 6E — null = pending (entered, not yet on the statement)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt // Phase 6E
  createdBy   String

  account   BankAccount @relation(fields: [accountId], references: [id])
  valuation Valuation?  @relation(fields: [valuationId], references: [id])
  project   Project?    @relation(fields: [projectId], references: [id]) // Phase 6E — was a bare String
  expense   Expense?    @relation(fields: [expenseId], references: [id]) // Phase 6E — was a bare String

  @@index([accountId, txnDate])
  @@index([projectId])
  @@index([valuationId]) // Phase 6E
  @@index([expenseId]) // Phase 6E
}
