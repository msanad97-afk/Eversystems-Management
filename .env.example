# ─── Database ──────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# On Vercel + Neon: DATABASE_URL is the POOLED string (host contains "-pooler");
# DIRECT_URL is the UNPOOLED string used by `prisma migrate` and scripts/createAdmin.ts.
# Locally you can point both at the same instance.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/eversystems?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/eversystems?schema=public"

# ─── NextAuth ──────────────────────────────────────────────────────────────
# Generate a secret with:  openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# ─── Email (Brevo SMTP) ────────────────────────────────────────────────────
SMTP_HOST="smtp-relay.brevo.com"
SMTP_PORT="587"
SMTP_USER="your-brevo-login"
SMTP_PASSWORD="your-brevo-smtp-key"
SMTP_FROM="Eversystems Management <no-reply@yourcompany.com>"

# ─── Seed admin ────────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL="admin@yourcompany.com"
SEED_ADMIN_PASSWORD="ChangeMe!2026"
